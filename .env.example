# OpenRouter API key (required for LLM inference)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Agent budget in USD (default: 5.00)
# RSI_BUDGET_USD=5.00

# LLM model name (default: "default" — routes to minimax-m2.7 via litellm)
# RSI_MODEL=default

# Max agent turns per session (0 = unlimited)
# RSI_MAX_TURNS=0

# Proxy domain allowlist (comma-separated, default: httpbin.org)
# PROXY_ALLOWLIST=httpbin.org

# Agent workspace GitHub repo (for session persistence)
# GIT_REMOTE_URL=https://github.com/ashtonleee/rsi-econ-agent-workspace.git

# Exa.ai search API (optional, free tier works without key)
# EXA_API_KEY=your-key-here

# Provider API keys (added by cli/providers.py add)
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# MISTRAL_API_KEY=
# TOGETHERAI_API_KEY=
# DEEPSEEK_API_KEY=

# Discord bot (operator dashboard — replaces webhook notifications)
# DISCORD_BOT_TOKEN=your-bot-token-here
# DISCORD_GUILD_ID=your-guild-id-here
# RSI_BRIDGE_URL=http://localhost:8081
