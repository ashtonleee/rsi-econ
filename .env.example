# OpenRouter API key (required for LLM inference)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Agent budget in USD (default: 5.00)
# RSI_BUDGET_USD=5.00

# LLM model name (default: "default" — routes to minimax-m2.7 via litellm)
# RSI_MODEL=default

# Max agent turns per session (0 = unlimited)
# RSI_MAX_TURNS=0

# Proxy domain allowlist (comma-separated, default: httpbin.org)
# PROXY_ALLOWLIST=httpbin.org

# Agent workspace GitHub repo (for session persistence)
# GIT_REMOTE_URL=https://github.com/ashtonleee/rsi-econ-agent-workspace.git
