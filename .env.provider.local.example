# Trusted-side only. Keep `.env.provider.local` untracked and out of the agent.

# Required for provider_passthrough.
OPENAI_API_KEY=replace-with-real-provider-key

# Optional. Trusted-side OpenAI-compatible base URL.
# OpenAI: https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
RSI_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Default model for `./scripts/provider.sh smoke`.
# OpenRouter commonly wants a fully-qualified provider/model name.
RSI_PROVIDER_SMOKE_MODEL=gpt-4.1-mini

# Optional. Default model for `./scripts/provider.sh answer-packet`.
# OpenRouter commonly wants a fully-qualified provider/model name.
RSI_PROVIDER_ANSWER_MODEL=gpt-4.1-mini

# Optional. Needed only for browser-backed/provider-backed runs that fetch live pages.
RSI_WEB_ALLOWLIST_HOSTS=docs.python.org
RSI_LLM_BUDGET_TOKEN_CAP=4000
